# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is blocked by .gitignore.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini
VITE_GEMINI_API_KEY=your_gemini_api_key

# WhatsApp Business API (set as Supabase secrets for Edge Functions)
# supabase secrets set WHATSAPP_VERIFY_TOKEN=...
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Blink (if used)
VITE_BLINK_PROJECT_ID=your_blink_project_id
VITE_BLINK_PUBLISHABLE_KEY=your_blink_publishable_key
